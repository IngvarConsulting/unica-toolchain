{
  "schemaVersion": 3,
  "name": "bsl-analyzer",
  "version": "0.2.55",
  "buildRevision": 1,
  "source": {
    "kind": "release",
    "repository": "https://github.com/itrous/bsl-analyzer",
    "ref": "v0.2.55",
